# Application
APP_NAME=AI-News-Podcast-Agent
DEBUG=True
HOST=0.0.0.0
PORT=9800

# DashScope (必填 — 通义千问 API Key)
DASHSCOPE_API_KEY=sk-your-api-key-here
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# News Collection
NEWS_COLLECTION_INTERVAL_MINUTES=30
NEWS_MAX_ITEMS=15
NEWS_IMPORTANCE_THRESHOLD=4
NEWS_KEYWORDS=AI,人工智能,大模型,机器学习,芯片,自动驾驶,LLM,GPT,Claude
NEWS_KEYWORDS_MODE=boost

# TTS (默认 edge-tts，免费无需 API Key)
TTS_PROVIDER=edge_tts
TTS_VOICE_ZH=zh-CN-YunxiNeural
TTS_VOICE_EN=en-US-JennyNeural
TTS_VOICE_ZH_EXPERT=zh-CN-YunyangNeural
TTS_RATE_SLOW=-5%
TTS_RATE_NORMAL=+5%
TTS_RATE_FAST=+15%
TTS_PITCH=+0Hz
TTS_VOLUME=+0%

# Audio
AUDIO_SAMPLE_RATE=24000
AUDIO_FORMAT=mp3
AUDIO_SEGMENT_MAX_DURATION=180

# Stream
STREAM_BUFFER_SIZE=4096
STREAM_BITRATE=128k

# Database
DATABASE_PATH=data/podcast.db

# Chroma 向量数据库
CHROMA_PATH=data/chroma
EMBEDDING_MODEL=text-embedding-v2
